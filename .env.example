# ============================================================
#  RAG 智能问答系统 - Docker 环境变量
#  复制此文件为 .env 并修改敏感值
# ============================================================

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_DATABASE=rag_db
MYSQL_USER=rag
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_PORT=3306

# ---------- Neo4j ----------
NEO4J_AUTH=neo4j/your_neo4j_password_here
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_HTTP_PORT=7700
NEO4J_BOLT_PORT=7687

# ---------- ChromaDB ----------
CHROMA_PORT=8000

# ---------- 后端 (FastAPI) ----------
BACKEND_PORT=8080
# 大模型 API
LLM_API_KEY=your_llm_api_key_here
LLM_API_URL=https://token-plan-cn.xiaomimimo.com/v1/chat/completions
LLM_MODEL=mimo-v2.5-pro
# Embedding API
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_API_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_DIM=1024
LLM_TIMEOUT=120
EMBEDDING_TIMEOUT=30

# ---------- 前端 ----------
FRONTEND_PORT=5173

# ---------- Nginx ----------
NGINX_PORT=80

# ---------- JWT ----------
JWT_SECRET=your_jwt_secret_here_at_least_32_chars
